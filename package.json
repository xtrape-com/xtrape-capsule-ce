{
  "name": "xtrape-capsule-ce",
  "version": "0.3.0",
  "description": "Xtrape Capsule Community Edition monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm --filter opstage-backend build && pnpm --filter demo-capsule-service build",
    "dev": "pnpm --filter opstage-backend dev",
    "typecheck": "pnpm --filter opstage-backend typecheck && pnpm --filter demo-capsule-service typecheck",
    "test": "pnpm --filter opstage-backend test",
    "db:generate": "pnpm --filter opstage-backend db:generate",
    "db:migrate": "pnpm --filter opstage-backend db:migrate",
    "db:studio": "pnpm --filter opstage-backend db:studio",
    "db:validate": "pnpm --filter opstage-backend db:validate"
  },
  "dependencies": {
    "@xtrape/capsule-agent-node": "^0.3.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "@types/node": "^22.10.2",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}