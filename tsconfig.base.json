{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@xtrape/capsule-contracts": ["packages/contracts/src/index.ts"],
      "@xtrape/capsule-db": ["packages/db/src/index.ts"],
      "@xtrape/capsule-shared": ["packages/shared/src/index.ts"],
      "@xtrape/capsule-agent-node": ["packages/agent-node/src/index.ts"],
      "@xtrape/capsule-test-utils": ["packages/test-utils/src/index.ts"]
    }
  }
}
