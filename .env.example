OPSTAGE_HOST=0.0.0.0
OPSTAGE_PORT=8080
OPSTAGE_DATA_DIR=./data
DATABASE_URL=file:./data/opstage.db

OPSTAGE_ADMIN_USERNAME=admin@example.local
OPSTAGE_ADMIN_PASSWORD=ChangeMeBeforeRunning123!
OPSTAGE_SESSION_SECRET=replace-with-a-long-random-secret
OPSTAGE_PUBLIC_BASE_URL=http://localhost:8080
OPSTAGE_STATIC_DIR=apps/opstage-ui/dist

OPSTAGE_AGENT_OFFLINE_THRESHOLD_SECONDS=90
OPSTAGE_AUDIT_RETENTION_DAYS=90
OPSTAGE_MAINTENANCE_INTERVAL_SECONDS=60
OPSTAGE_BACKUP_DIR=./data/backups

# v0.4 experimental Capsule Bus. Disabled by default; enable only for controlled trials.
OPSTAGE_CAPSULE_BUS_ENABLED=false
